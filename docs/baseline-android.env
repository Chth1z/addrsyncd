# Default Android benchmark gate values.
# Run `RECORD_BASELINE=1 sh ./bench_android.sh` on real device to regenerate.

BASELINE_CAPTURED_AT=UNSET
BASELINE_DURATION_SEC=60
BASELINE_SAMPLE_SEC=2
BASELINE_CPU_TICKS_DELTA=0
BASELINE_LOG_LINES_DELTA=0
BASELINE_COUNT_RULE_BATCH=0
BASELINE_COUNT_EVENT_DROP=0
BASELINE_COUNT_COMPENSATE_RESYNC=0

BASELINE_MAX_CPU_TICKS_DELTA=1000000
BASELINE_MAX_EVENT_DROP=0
BASELINE_MAX_COMPENSATE_RESYNC=0
